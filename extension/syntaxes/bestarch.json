{
  "scopeName": "source.bestarch",
  "patterns": [
    {
      "name": "comment.line.number-sign.bestarch",
      "match": "#.*$"
    },
    {
      "name": "keyword.bestarch",
      "match": "(?:\\.const_i8|\\.const_i16|\\.const_i32|\\.const_i64\\.allocz\\.embed)\\b"
    },
    {
      "name": "variable.bestarch",
      "match": "(\\.[.:_a-zA-Z][.:_a-zA-Z0-9]*)|([.:_a-zA-Z][.:_a-zA-Z0-9]*:)"
    },
    {
      "name": "variable.predefined.bestarch",
      "match": "\\br(?:[0-9]|[1-2][0-9]|3[0-1]|Z)\\b"
    },
    {
      "name": "variable.other.enummember.bestarch",
      "match": "\\b(?:xctl|xhwi|xtmi|xswi)\\b"
    },
    {
      "name": "keyword.bestarch",
      "match": "[.:_a-zA-Z][.:_a-zA-Z0-9]*"
    },
    {
      "name": "keyword.operator.bestarch",
      "match": "(,|\\+|<<|>>)"
    },
    {
      "name": "constant.numeric.hex.bestarch",
      "match": "\\b0x[0-9a-fA-F]+\\b"
    },
    {
      "name": "constant.numeric.binary.bestarch",
      "match": "\\b0b[01]+\\b"
    },
    {
      "name": "constant.numeric.decimal.bestarch",
      "match": "\\b[0-9]+\\b"
    }
  ]
}